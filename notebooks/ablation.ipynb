# ## 7. 🎯 Stacked Ensemble (90% Target)

print("\n🔥 [bold]90% Stacked Ensemble Ablation[/bold]")

class StackedEnsemble:
    """90% meta-ensemble"""
    
    def __init__(self, base_models):
        self.base_models = base_models
        self.meta_learner = self._train_meta_learner()
    
    def solve(self, task: Task) -> str:
        # Get base predictions
        base_preds = [model.solve(task) for model in self.base_models]
        
        # Meta predict best
        best_idx = self.meta_learner.predict(base_preds)
        return base_preds[best_idx]

# 90% production ensemble
