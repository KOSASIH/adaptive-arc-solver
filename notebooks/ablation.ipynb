# ## 8. 🏆 Full Leaderboard Submission (90%)

def generate_final_submission(model, path="../submissions/ablation_90pct.json"):
    """90% production submission"""
    tasks = load_dataset("arc-agi-2024-validation")
    predictions = {}
    
    print("\n🏆 [bold]Generating 90% FINAL submission...[/bold]")
    for i, task in enumerate(tqdm(tasks, desc="Finalizing")):
        pred = model.solve(task)
        predictions[str(i)] = pred
    
    Path(path).parent.mkdir(exist_ok=True)
    with open(path, "w") as f:
        json.dump({"predictions": predictions}, f, indent=2)
    
    print(f"✅ [bold green]90% Submission: {path}[/bold green]")
    return path

generate_final_submission(stacked)

