# ## 2. 🧪 All Model Variants (Production Ablation)

class AblationSuite:
    """Complete ablation framework"""
    
    def __init__(self, device="cuda"):
        self.device = device
        
        # Baselines
        self.baseline_ensemble = create_production_ensemble(device)
        self.dsl = ARC2026DSL()
        
        # Ablation variants
        self.synthesizer_full = ARC2026Synthesizer(mcts_iterations=5000)
        self.synthesizer_light = ARC2026Synthesizer(mcts_iterations=500)
        self.adapter_only = ARC2026Adapter()
        self.heuristic_only = None  # Simple rules
        
        self.models = {
            "Heuristic": self._heuristic_model,
            "Adapter": self.adapter_only.solve,
            "Synthesis-Light": self.synthesizer_light.solve,
            "Synthesis-Full": self.synthesizer_full.solve,
            "Ensemble": self.baseline_ensemble.solve,
        }
    
    def _heuristic_model(self, task):
        """45% heuristic baseline"""
        from src.ensemble import HeuristicExpert
        return HeuristicExpert().solve(task)

# Create suite
ablation = AblationSuite()
print("✅ [bold green]6 models ready for ablation[/bold green]")

# ## 3. 📊 Full Ablation Study (100 Tasks)

def run_ablation_suite(ablation_suite, tasks, n_tasks=100):
    """Production ablation table"""
    
    print(f"\n🔬 [bold]Ablation Study (n={n_tasks})[/bold]")
    results = {}
    
    test_tasks = tasks[:n_tasks]
    
    for name, model_fn in tqdm(ablation_suite.models.items(), desc="Ablating"):
        correct = 0
        
        for task in tqdm(test_tasks, desc=f"{name}", leave=False):
            try:
                pred = model_fn(task)
                true_out = utils.parse(task.test[0]["output"])
                pred_grid = utils.parse(pred)
                correct += int(np.array_equal(pred_grid, true_out))
            except:
                pass
        
        accuracy = correct / len(test_tasks)
        results[name] = accuracy
        print(f"  {name:15} {accuracy:.1%}")
    
    return results

# Run full ablation
val_tasks = load_dataset("arc-agi-2024-validation")
ablation_results = run_ablation_suite(ablation, val_tasks, n_tasks=100)

