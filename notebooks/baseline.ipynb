# ## 5. 📤 Kaggle Submission Generator

def generate_submission(model, dataset_name="arc-agi-2024-validation"):
    """Production submission JSON"""
    print(f"\n📤 Generating {dataset_name} submission...")
    
    tasks = load_dataset(dataset_name)
    predictions = {}
    
    for task_id, task in enumerate(tasks):
        print(f"  Solving task {task_id+1}/{len(tasks)}")
        pred = model.solve(task)
        predictions[str(task_id)] = pred
    
    # Save submission
    submission = {"predictions": predictions}
    with open("../submissions/baseline.json", "w") as f:
        json.dump(submission, f, indent=2)
    
    print(f"✅ [bold green]Submission saved: submissions/baseline.json[/bold green]")
    return submission

# Generate leaderboard submission
submission = generate_submission(model, "arc-agi-2024-validation")
print(f"📊 Expected private score: [bold]{full_results['accuracy']:.1%}[/bold]")

# ## 6. ⚙️ Production Speed Test

import time
from tqdm.auto import tqdm

print("\n⏱️  Production speed test (100 tasks)...")

times = []
for task in tqdm(load_dataset("arc-agi-2024-validation")[:100]):
    start = time.time()
    _ = model.solve(task)
    times.append(time.time() - start)

print(f"🚀 [bold green]Mean: {np.mean(times)*1000:.1f}ms | 95th: {np.percentile(times, 95)*1000:.1f}ms[/bold green]")
print(f"💨 [bold cyan]{1000/np.mean(times):.1f} tasks/second[/bold cyan]")

# ## 7. 🧠 Live Task Inspector (Copy any task JSON)

def inspect_task(task_json: str):
    """Interactive task debugging"""
    import json
    task = json.loads(task_json)
    
    print("🔍 [bold]TASK ANALYSIS[/bold]")
    print(f"Train pairs: [cyan]{len(task['train'])}[/cyan]")
    
    # Show first train pair
    inp = utils.parse(task["train"][0]["input"])
    out = utils.parse(task["train"][0]["output"])
    
    import matplotlib.pyplot as plt
    fig, axes = plt.subplots(1, 4, figsize=(12, 3))
    axes[0].imshow(inp, vmin=0, vmax=9)
    axes[0].set_title("Input")
    axes[1].imshow(out, vmin=0, vmax=9) 
    axes[1].set_title("Output")
    
    pred = model.solve(Task.parse_obj(task))
    pred_grid = utils.parse(pred)
    axes[2].imshow(pred_grid, vmin=0, vmax=9)
    axes[2].set_title("Prediction")
    
    correct = np.array_equal(pred_grid, out)
    axes[3].imshow(pred_grid == out, vmin=0, vmax=1, cmap="RdYlGn")
    axes[3].set_title(f"Correct: {'✅' if correct else '❌'}")
    
    plt.tight_layout()
    plt.show()

