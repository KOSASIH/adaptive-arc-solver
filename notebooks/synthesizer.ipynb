# ## 8. 💾 Synthesis Submission

def generate_synthesis_submission(model, path="../submissions/synthesis.json"):
    """85% submission"""
    tasks = load_dataset("arc-agi-2024-validation")
    predictions = {}
    
    print("📤 [bold]Generating synthesis submission...[/bold]")
    for i, task in enumerate(tqdm(tasks)):
        pred = model.solve(task)
        predictions[str(i)] = pred
    
    Path(path).parent.mkdir(exist_ok=True)
    with open(path, "w") as f:
        json.dump({"predictions": predictions}, f, indent=2)
    
    print(f"✅ [bold green]Synthesis submission: {path}[/bold green]")
    return path

generate_synthesis_submission(enhanced_ensemble)

