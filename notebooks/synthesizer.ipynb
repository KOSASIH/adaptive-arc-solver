# ## 4. 🎯 Synthesis vs Ensemble Comparison

def compare_models(tasks: List[Task], n: int = 50):
    """Synthesis vs Ensemble head-to-head"""
    
    synth_correct = 0
    ens_correct = 0
    both_correct = 0
    
    ensemble = ARC2026Ensemble()
    
    print(f"\n⚔️  Comparing on {n} tasks...")
    for i, task in enumerate(tqdm(tasks[:n])):
        # Synthesis
        synth_pred = synthesizer.solve(task)
        synth_grid = utils.parse(synth_pred)
        synth_correct += np.array_equal(synth_grid, utils.parse(task.test[0]["output"]))
        
        # Ensemble  
        ens_pred = ensemble.solve(task)
        ens_grid = utils.parse(ens_pred)
        ens_correct += np.array_equal(ens_grid, utils.parse(task.test[0]["output"]))
        
        if synth_correct and ens_correct:
            both_correct += 1
    
    print(f"\n📊 [bold]Results:[/bold]")
    print(f"   Synthesis:  [green]{synth_correct/n:.1%}[/green]")
    print(f"   Ensemble:   [blue]{ens_correct/n:.1%}[/blue]") 
    print(f"   Both:       [yellow]{both_correct/n:.1%}[/yellow]")
    print(f"   Synthesis wins: [bold cyan]{(synth_correct > ens_correct)}[/bold cyan]")
    
    return {
        "synthesis": synth_correct/n,
        "ensemble": ens_correct/n,
        "both": both_correct/n
    }

# Test comparison
val_tasks = load_dataset("arc-agi-2024-validation")
comparison = compare_models(val_tasks)

# ## 5. 🧪 Live Program Synthesis Demo

def demo_synthesis(task: Task, show_program: bool = True):
    """Interactive synthesis demo"""
    
    print("\n🔬 [bold]Live Synthesis Demo[/bold]")
    
    # Analyze task
    inp = utils.parse(task.train[0]["input"])
    true_out = utils.parse(task.train[0]["output"])
    test_inp = utils.parse(task.test[0]["input"])
    
    # Synthesize
    program = synthesizer._mcts_search(task, {})  # Internal call
    pred = synthesizer._execute_program(program, test_inp)
    
    # Visualize
    fig, axes = plt.subplots(2, 4, figsize=(16, 8))
    
    axes[0,0].imshow(inp); axes[0,0].set_title("Train Input")
    axes[0,1].imshow(true_out); axes[0,1].set_title("Train Output") 
    axes[0,2].imshow(test_inp); axes[0,2].set_title("Test Input")
    axes[0,3].imshow(pred); axes[0,3].set_title("Synthesis Pred")
    
    # Step-by-step execution
    grid = test_inp.copy()
    for i, op_name in enumerate(program):
        grid = dsl.operations[op_name](grid)
        axes[1,i].imshow(grid)
        axes[1,i].set_title(f"Step {i+1}: {op_name}")
    
    correct = np.array_equal(pred, utils.parse(task.test[0]["output"]))
    axes[0,3].text(0.5, -0.1, f"✅ CORRECT" if correct else "❌ WRONG", 
                   ha='center', va='top', transform=axes[0,3].transAxes,
                   fontsize=16, color='green' if correct else 'red')
    
    plt.tight_layout()
    plt.show()
    
    if show_program:
        print(f"🧬 [bold]Discovered Program:[/bold] [cyan]{program}[/cyan]")
        print(f"✅ [bold green]Correct: {'YES' if correct else 'NO'}[/bold green]")

# Demo first solvable task
for task in val_tasks:
    try:
        demo_synthesis(task)
        break
    except:
        continue

# ## 6. 📈 Full Synthesis Benchmark

print("\n🏁 [bold]Full synthesis benchmark (300 tasks)...[/bold]")

def benchmark_synthesis(synth, tasks):
    """Production synthesis eval"""
    correct = 0
    programs = []
    
    for task in tqdm(tasks, desc="Synthesizing"):
        pred = synth.solve(task)
        true_out = utils.parse(task.test[0]["output"])
        pred_grid = utils.parse(pred)
        
        if np.array_equal(pred_grid, true_out):
            correct += 1
        
        # Track programs for analysis
        programs.append({
            "task_id": len(programs),
            "correct": np.array_equal(pred_grid, true_out),
            "pred": pred
        })
    
    accuracy = correct / len(tasks)
    return accuracy, programs

synth_accuracy, synth_programs = benchmark_synthesis(synthesizer, val_tasks)

print(f"\n🧬 [bold green]SYNTHESIS ACCURACY: {synth_accuracy:.1%}[/bold green]")
print(f"📈 [bold]Improvement: +{synth_accuracy - comparison['synthesis']:+.1%}[/bold]")

# ## 7. 🎯 Synthesis-Enhanced Ensemble (85% Target)

print("\n🔬 [bold]Synthesis-Enhanced Ensemble...[/bold]")

class SynthesisEnsemble(ARC2026Ensemble):
    """Ensemble with synthesis priority"""
    
    def __init__(self, synthesizer, *args, **kwargs):
        super().__init__(*args, **kwargs)
        self.synthesizer = synthesizer
        self.experts["synthesis"] = self.synthesizer
    
    def solve(self, task: Task) -> str:
        # Try synthesis first (highest weight)
        try:
            synth_pred = self.synthesizer.solve(task)
            # Quick validation
            if self._validate_synth(synth_pred, task.train):
                return synth_pred
        except:
            pass
        
        # Fallback to base ensemble
        return super().solve(task)
    
    def _validate_synth(self, pred_json: str, train_pairs: List) -> bool:
        pred_grid = utils.parse(pred_json)
        for pair in train_pairs[:2]:
            inp_grid = utils.parse(pair["input"])
            expected = utils.parse(pair["output"])
            synth_grid = self.synthesizer._execute_program([], inp_grid)  # Test
            if not np.array_equal(synth_grid, expected):
                return False
        return True

